POSTGRES_DB=momentum_task
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_real_env

# URL for running the app outside Docker (e.g. uvicorn on host)
DATABASE_URL=postgresql+psycopg://postgres:change_me_in_real_env@localhost:5432/momentum_task

# URL used by Docker services (host 'db' is available only inside compose network)
DATABASE_URL_DOCKER=postgresql+psycopg://postgres:change_me_in_real_env@db:5432/momentum_task

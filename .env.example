# Dummy values for recruitment/test runs. Replace in real environments.
POSTGRES_DB=momentum_task
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_real_env

# Dummy value for test: URL for running the app outside Docker (e.g. uvicorn on host)
